{
  "name": "@kitsunekode/loom",
  "version": "0.1.1",
  "description": "Preview-first dotfiles workflow CLI built on top of chezmoi.",
  "type": "module",
  "license": "MIT",
  "author": "kitsunekode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KitsuneKode/loom-cli.git"
  },
  "homepage": "https://github.com/KitsuneKode/loom-cli#readme",
  "bugs": {
    "url": "https://github.com/KitsuneKode/loom-cli/issues"
  },
  "keywords": [
    "bun",
    "chezmoi",
    "cli",
    "dotfiles",
    "sync",
    "tooling"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/loom",
    "dist/loom.js",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "bin": {
    "loom": "bin/loom"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "scripts": {
    "dev": "bun run src/bin/loom.ts",
    "build": "mkdir -p dist && bun build src/bin/loom.ts --outfile dist/loom.js --target bun --minify",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "version-packages": "changeset version && bun install",
    "release": "changeset publish",
    "check": "bun run typecheck && bun test && bun run build",
    "pkg:check": "bun run build && npm pack --dry-run --ignore-scripts",
    "release:dry-run": "npm publish --dry-run --access public",
    "link:global": "bun run build && bun link",
    "unlink:global": "bun unlink",
    "prepack": "bun run build",
    "prepublishOnly": "bun run check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
